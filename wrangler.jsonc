{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-threat-atlas",
  "main": "./worker.js",
  "compatibility_date": "2026-04-27",
  "routes": [
    { "pattern": "atlas.clawforceone.ai", "custom_domain": true },
    { "pattern": "atlas.matejlukasik.com", "custom_domain": true },
    { "pattern": "atlas.matejlukasik.sk", "custom_domain": true }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/contact*"],
    "not_found_handling": "404-page"
  }
}
