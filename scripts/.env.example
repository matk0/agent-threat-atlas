# Copy to .env and fill in. Never commit .env.
# `source scripts/.env` before running, or use a tool like `direnv` / `dotenv`.

# Required for a real scraper run. Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Defaults to claude-haiku-4-5-20251001 (cheap and fast for classification).
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional. A GitHub token raises the GitHub Advisory API rate limit from
# 60 to 5000 requests/hour. Read-only public-data scope is plenty.
# GITHUB_TOKEN=ghp_...

# Optional. Override the User-Agent the scraper sends to source feeds.
# USER_AGENT="AgentThreatAtlas-Scraper/1.0 (+https://atlas.clawforceone.ai)"
