# Copy to .env and fill in. Never commit .env.
# `source scripts/.env` before running, or use a tool like `direnv` / `dotenv`.

# Required for a real scraper run with the default provider.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Defaults to claude-3-5-haiku-20241022.
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Optional fallback provider.
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_MODEL=stepfun-ai/step-3.5-flash

# Optional. Defaults to 100 candidates per production run.
# SCRAPER_LIMIT=100

# Optional. Defaults to 30. Larger values backfill only trusted incident sources.
# SCRAPER_BACKFILL_DAYS=365

# Required for Slovak localization. Used by scripts/translate-content.mjs.
DEEPL_AUTH_KEY=...

# Optional. A GitHub token raises the GitHub Advisory API rate limit from
# 60 to 5000 requests/hour. Read-only public-data scope is plenty.
# GITHUB_TOKEN=ghp_...

# Optional. Override the User-Agent the scraper sends to source feeds.
# USER_AGENT="AgentThreatAtlas-Scraper/1.0 (+https://atlas.matejlukasik.com)"
