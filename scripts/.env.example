# Copy to .env and fill in. Never commit .env.
# `source scripts/.env` before running, or use a tool like `direnv` / `dotenv`.

# Required for a real scraper run. Get one at https://build.nvidia.com.
NVIDIA_API_KEY=nvapi-...

# Optional. Defaults to stepfun-ai/step-3.5-flash.
# NVIDIA_MODEL=stepfun-ai/step-3.5-flash

# Optional. Defaults to 20 candidates per production run.
# SCRAPER_LIMIT=20

# Required for Slovak localization. Used by scripts/translate-content.mjs.
DEEPL_AUTH_KEY=...

# Optional. A GitHub token raises the GitHub Advisory API rate limit from
# 60 to 5000 requests/hour. Read-only public-data scope is plenty.
# GITHUB_TOKEN=ghp_...

# Optional. Override the User-Agent the scraper sends to source feeds.
# USER_AGENT="AgentThreatAtlas-Scraper/1.0 (+https://atlas.matejlukasik.com)"
